services:
  unitask:
    build: .
    restart: unless-stopped
    user: "1003:1003"
    container_name: unitask-app
    env_file:
      - .env
    expose:
      - "9000"
    networks:
      - main-network

    volumes:
      - ./storage:/var/www/storage
      - ./bootstrap/cache:/var/www/bootstrap/cache
      - ./database:/var/www/database

networks:
  main-network:
    external: true